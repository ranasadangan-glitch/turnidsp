# ── Core ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# (3) STRONG JWT — REQUIRED in production: >= 64 chars. The app refuses to start otherwise.
#   generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-generate-a-64-plus-character-random-secret
JWT_TTL=30m                 # (7) short-lived access token (session inactivity window)
REFRESH_DAYS=7              # refresh token lifetime

# ── Database ───────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   # SSL auto-enabled when set
# PGSSL=true
PGHOST=localhost
PGPORT=5432
PGUSER=turnidsp
PGPASSWORD=turnidsp
PGDATABASE=turnidsp
PG_POOL_MAX=20

# ── (4) Login protection ───────────────────────────────────────
LOGIN_RATE_MAX=20           # IP rate-limit per 15 min
LOCK_MAX_FAILS=5            # failed attempts before temporary lockout
LOCK_WINDOW_MIN=15         # lockout window (minutes)

# ── (1) CORS / HTTPS ───────────────────────────────────────────
# CORS_ORIGIN=https://app.tuodominio.it       # empty = same-origin only
# PUBLIC_URL=https://app.tuodominio.it        # used in password-reset links

# ── (8) Password reset email (optional SMTP) ───────────────────
# SMTP_HOST=smtp.aruba.it
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM=no-reply@tuodominio.it
# RESET_TTL_MIN=30

# ── (9) Document storage / antivirus ───────────────────────────
# UPLOAD_DIR=/var/data/uploads     # persistent volume/disk
# CLAMAV_HOST=127.0.0.1            # enable virus scanning if a clamd is reachable
# CLAMAV_PORT=3310

# ── First-run / recovery admin ─────────────────────────────────
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=choose-a-strong-one
# RESET_ADMIN=true                 # force-reset admin password on next deploy, then remove
