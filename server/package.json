{
  "name": "turnidsp-platform",
  "version": "1.0.0",
  "description": "TurniDSP Workforce Management Platform — Amazon DSP",
  "type": "commonjs",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/db/migrate.js && node src/app.js",
    "serve": "node src/app.js",
    "dev": "node --watch src/app.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/migrate.js --seed",
    "reset-admin": "node scripts/reset-admin.js",
    "hash": "node scripts/hash.js"
  },
  "engines": {
    "node": ">=18 <23"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5"
  }
}
